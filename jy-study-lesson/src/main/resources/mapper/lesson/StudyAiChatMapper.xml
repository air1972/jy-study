<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jy.study.lesson.mapper.StudyAiChatMapper">
    
    <resultMap type="StudyAiChat" id="StudyAiChatResult">
        <result property="chatId"    column="chat_id"    />
        <result property="conversationId"    column="conversation_id"    />
        <result property="userId"    column="user_id"    />
        <result property="role"    column="role"    />
        <result property="content"    column="content"    />
        <result property="model"    column="model"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectStudyAiChatVo">
        select chat_id, conversation_id, user_id, role, content, model, status, create_time, update_time 
        from study_ai_chat
    </sql>

    <select id="selectStudyAiChatList" parameterType="StudyAiChat" resultMap="StudyAiChatResult">
        <include refid="selectStudyAiChatVo"/>
        <where>  
            <if test="conversationId != null  and conversationId != ''"> and conversation_id = #{conversationId}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="role != null  and role != ''"> and role = #{role}</if>
            <if test="model != null  and model != ''"> and model = #{model}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="content != null and content != ''"> and content like concat('%', #{content}, '%')</if>
        </where>
        order by create_time asc
    </select>
    
    <select id="selectStudyAiChatById" parameterType="Long" resultMap="StudyAiChatResult">
        <include refid="selectStudyAiChatVo"/>
        where chat_id = #{chatId}
    </select>
        
    <insert id="insertStudyAiChat" parameterType="StudyAiChat" useGeneratedKeys="true" keyProperty="chatId">
        insert into study_ai_chat
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="conversationId != null and conversationId != ''">conversation_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="role != null">role,</if>
            <if test="content != null">content,</if>
            <if test="model != null">model,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="conversationId != null and conversationId != ''">#{conversationId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="role != null">#{role},</if>
            <if test="content != null">#{content},</if>
            <if test="model != null">#{model},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateStudyAiChat" parameterType="StudyAiChat">
        update study_ai_chat
        <trim prefix="SET" suffixOverrides=",">
            <if test="conversationId != null">conversation_id = #{conversationId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="role != null">role = #{role},</if>
            <if test="content != null">content = #{content},</if>
            <if test="model != null">model = #{model},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where chat_id = #{chatId}
    </update>

    <delete id="deleteStudyAiChatById" parameterType="Long">
        delete from study_ai_chat where chat_id = #{chatId}
    </delete>

    <delete id="deleteStudyAiChatByIds" parameterType="String">
        delete from study_ai_chat where chat_id in 
        <foreach item="chatId" collection="array" open="(" separator="," close=")">
            #{chatId}
        </foreach>
    </delete>
</mapper> 