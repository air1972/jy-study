<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jy.study.lesson.mapper.StudyOnlineChatMuteMapper">

    <resultMap type="StudyOnlineChatMute" id="StudyOnlineChatMuteResult">
        <result property="muteId" column="mute_id"/>
        <result property="userId" column="user_id"/>
        <result property="roomCode" column="room_code"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="status" column="status"/>
        <result property="reason" column="reason"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectActiveMute" resultMap="StudyOnlineChatMuteResult">
        select mute_id, user_id, room_code, start_time, end_time, status, reason,
               create_by, create_time, update_by, update_time
        from study_online_chat_mute
        where user_id = #{userId}
          and status = '0'
          and start_time &lt;= #{now}
          and end_time &gt;= #{now}
          and (room_code = #{roomCode} or room_code = '*')
        order by case when room_code = #{roomCode} then 0 else 1 end asc, end_time desc
        limit 1
    </select>

    <insert id="insertStudyOnlineChatMute" parameterType="StudyOnlineChatMute" useGeneratedKeys="true" keyProperty="muteId">
        insert into study_online_chat_mute
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="roomCode != null and roomCode != ''">room_code,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="reason != null and reason != ''">reason,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="roomCode != null and roomCode != ''">#{roomCode},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="reason != null and reason != ''">#{reason},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="disableRoomMute">
        update study_online_chat_mute
        set status = '1',
            update_by = #{updateBy},
            update_time = #{updateTime}
        where user_id = #{userId}
          and room_code = #{roomCode}
          and status = '0'
    </update>

    <delete id="deleteMutesByRoomCode">
        delete from study_online_chat_mute
        where room_code = #{roomCode}
    </delete>
</mapper>
