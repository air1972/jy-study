<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jy.study.lesson.mapper.StudyOnlineChatSensitiveWordMapper">

    <resultMap type="StudyOnlineChatSensitiveWord" id="StudyOnlineChatSensitiveWordResult">
        <result property="wordId" column="word_id"/>
        <result property="word" column="word"/>
        <result property="replaceText" column="replace_text"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectEnabledWords" resultMap="StudyOnlineChatSensitiveWordResult">
        select word_id, word, replace_text, status, create_time, update_time
        from study_online_chat_sensitive_word
        where status = '0'
        order by char_length(word) desc, word_id asc
    </select>
</mapper>
