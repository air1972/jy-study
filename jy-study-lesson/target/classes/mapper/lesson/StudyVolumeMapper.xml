<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jy.study.lesson.mapper.StudyVolumeMapper">

    <resultMap type="StudyVolume" id="StudyVolumeResult">
        <result property="volumeId"    column="volume_id"    />
        <result property="name"    column="name"    />
        <result property="code"    column="code"    />
        <result property="sort"    column="sort"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectStudyVolumeVo">
        select volume_id, name, code, sort, status, create_by, create_time, update_by, update_time, remark from study_volume
    </sql>

    <select id="selectStudyVolumeList" parameterType="StudyVolume" resultMap="StudyVolumeResult">
        <include refid="selectStudyVolumeVo"/>
        <where>
            <if test="volumeId != null"> and volume_id = #{volumeId}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="code != null  and code != ''"> and code = #{code}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by sort
    </select>

    <select id="selectStudyVolumeById" parameterType="Long" resultMap="StudyVolumeResult">
        <include refid="selectStudyVolumeVo"/>
        where volume_id = #{volumeId}
    </select>

    <insert id="insertStudyVolume" parameterType="StudyVolume" useGeneratedKeys="true" keyProperty="volumeId">
        insert into study_volume
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="code != null and code != ''">code,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="code != null and code != ''">#{code},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateStudyVolume" parameterType="StudyVolume">
        update study_volume
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="code != null and code != ''">code = #{code},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where volume_id = #{volumeId}
    </update>

    <delete id="deleteStudyVolumeById" parameterType="Long">
        delete from study_volume where volume_id = #{volumeId}
    </delete>

    <delete id="deleteStudyVolumeByIds" parameterType="Long">
        delete from study_volume where volume_id in
        <foreach item="volumeId" collection="array" open="(" separator="," close=")">
            #{volumeId}
        </foreach>
    </delete>

</mapper>
