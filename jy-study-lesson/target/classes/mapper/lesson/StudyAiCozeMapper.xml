<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jy.study.lesson.mapper.StudyAiCozeMapper">
    
    <resultMap type="StudyAiCoze" id="AiCozeResult">
        <id     property="id"           column="id"            />
        <result property="articleId"    column="article_id"    />
        <result property="questionNum"  column="question_num"  />
        <result property="content"      column="content"       />
        <result property="fileUrl"      column="file_url"      />
        <result property="debugUrl"     column="debug_url"     />
        <result property="status"       column="status"        />
        <result property="createTime"   column="create_time"   />
        <result property="updateTime"   column="update_time"   />
    </resultMap>

    <sql id="selectAiCozeVo">
        select id, article_id, question_num, content, file_url, debug_url, status, 
        create_time, update_time
        from study_ai_coze
    </sql>

    <select id="selectAiCozeList" parameterType="StudyAiCoze" resultMap="AiCozeResult">
        <include refid="selectAiCozeVo"/>
        <where>
            <if test="articleId != null ">
                AND article_id = #{articleId}
            </if>
            <if test="status != null  and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectAiCozeById" parameterType="Long" resultMap="AiCozeResult">
        <include refid="selectAiCozeVo"/>
        where id = #{id}
    </select>

    <select id="selectLatestByArticleId" parameterType="Long" resultMap="AiCozeResult">
        <include refid="selectAiCozeVo"/>
        where article_id = #{articleId}
        order by create_time desc limit 1
    </select>

<!--    这里是有主键回填的功能的useGeneratedKeys="true" : 告诉MyBatis使用JDBC的getGeneratedKeys方法来取出数据库内部生成的主键 keyProperty="id" : 指定把获取到的主键值赋给参数对象的哪个属性-->
    <insert id="insertAiCoze" parameterType="StudyAiCoze" useGeneratedKeys="true" keyProperty="id">
        insert into study_ai_coze
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="articleId != null">article_id,</if>
            <if test="questionNum != null">question_num,</if>
            <if test="content != null">content,</if>
            <if test="fileUrl != null">file_url,</if>
            <if test="debugUrl != null">debug_url,</if>
            <if test="status != null">status,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="articleId != null">#{articleId},</if>
            <if test="questionNum != null">#{questionNum},</if>
            <if test="content != null">#{content},</if>
            <if test="fileUrl != null">#{fileUrl},</if>
            <if test="debugUrl != null">#{debugUrl},</if>
            <if test="status != null">#{status},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAiCoze" parameterType="StudyAiCoze">
        update study_ai_coze
        <trim prefix="SET" suffixOverrides=",">
            <if test="questionNum != null">question_num = #{questionNum},</if>
            <if test="content != null">content = #{content},</if>
            <if test="fileUrl != null">file_url = #{fileUrl},</if>
            <if test="debugUrl != null">debug_url = #{debugUrl},</if>
            <if test="status != null">status = #{status},</if>
            update_time = sysdate()
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAiCozeById" parameterType="Long">
        delete from study_ai_coze where id = #{id}
    </delete>

    <delete id="deleteAiCozeByIds" parameterType="String">
        delete from study_ai_coze where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper> 