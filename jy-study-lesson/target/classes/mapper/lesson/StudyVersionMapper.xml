<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jy.study.lesson.mapper.StudyVersionMapper">

    <resultMap type="StudyVersion" id="StudyVersionResult">
        <result property="versionId"    column="version_id"    />
        <result property="name"    column="name"    />
        <result property="code"    column="code"    />
        <result property="sort"    column="sort"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectStudyVersionVo">
        select version_id, name, code, sort, status, create_by, create_time, update_by, update_time, remark from study_version
    </sql>

    <select id="selectStudyVersionList" parameterType="StudyVersion" resultMap="StudyVersionResult">
        <include refid="selectStudyVersionVo"/>
        <where>
            <if test="versionId != null"> and version_id = #{versionId}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="code != null  and code != ''"> and code = #{code}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by sort
    </select>

    <select id="selectStudyVersionById" parameterType="Long" resultMap="StudyVersionResult">
        <include refid="selectStudyVersionVo"/>
        where version_id = #{versionId}
    </select>

    <insert id="insertStudyVersion" parameterType="StudyVersion" useGeneratedKeys="true" keyProperty="versionId">
        insert into study_version
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="code != null and code != ''">code,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="code != null and code != ''">#{code},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateStudyVersion" parameterType="StudyVersion">
        update study_version
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="code != null and code != ''">code = #{code},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where version_id = #{versionId}
    </update>

    <delete id="deleteStudyVersionById" parameterType="Long">
        delete from study_version where version_id = #{versionId}
    </delete>

    <delete id="deleteStudyVersionByIds" parameterType="Long">
        delete from study_version where version_id in
        <foreach item="versionId" collection="array" open="(" separator="," close=")">
            #{versionId}
        </foreach>
    </delete>

</mapper>
