<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jy.study.lesson.mapper.StudyArticleMapper">

    <resultMap type="StudyArticle" id="StudyArticleResult">
        <id     property="articleId"    column="article_id"    />
        <result property="title"        column="title"         />
        <result property="content"      column="content"       />
        <result property="status"       column="status"        />
        <result property="sort"         column="sort"          />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />


        <result property="tags"         column="tags"          />
        <result property="summary"      column="summary"       />
        <result property="viewCount"    column="view_count"    />
        <result property="likeCount"    column="like_count"    />
        <result property="collectCount" column="collect_count" />
        <result property="top"          column="top"           />
        <result property="coverImg"     column="cover_img"     />
        <result property="voiceUrl"     column="voice_url"     />
        <result property="cozeId"       column="coze_id"       />
        <result property="versionId"    column="version_id"    />
        <result property="versionName"  column="version_name"  />
        <result property="subjectId"    column="subject_id"    />
        <result property="subjectName"  column="subject_name"  />
        <result property="gradeId"      column="grade_id"      />
        <result property="gradeName"    column="grade_name"    />
        <result property="volumeId"     column="volume_id"     />
        <result property="volumeName"   column="volume_name"   />
    </resultMap>

    <sql id="selectArticleVo">
        select article_id, title, content, status, sort, category_name, category_id, tags,
               cover_img, voice_url, coze_id,
               summary, view_count, like_count, collect_count, top,
               version_id, version_name, subject_id, subject_name, grade_id, grade_name, volume_id, volume_name,
               create_by, create_time, update_by, update_time, remark
        from study_article
    </sql>

    <select id="selectArticleList" parameterType="StudyArticle" resultMap="StudyArticleResult">
        <include refid="selectArticleVo"/>
        <where>
            <if test="title != null and title != ''">
                AND title like concat('%', #{title}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="versionName != null and versionName != ''">
                AND version_name = #{versionName}
            </if>
            <if test="subjectName != null and subjectName != ''">
                AND subject_name = #{subjectName}
            </if>
            <if test="gradeName != null and gradeName != ''">
                AND grade_name = #{gradeName}
            </if>
            <if test="volumeName != null and volumeName != ''">
                AND volume_name = #{volumeName}
            </if>
            <if test="tags != null and tags != ''">
                AND tags like concat('%', #{tags}, '%')
            </if>
            <if test="summary != null and summary != ''">
                AND summary like concat('%', #{summary}, '%')
            </if>
            <if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
                AND date_format(create_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
                AND date_format(create_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
        </where>
        <!-- 使用默认排序 -->
        <if test="sort != null">
            order by sort asc
        </if>
        <if test="sort == null">
            order by create_time desc
        </if>
    </select>

    <select id="selectArticleById" parameterType="Long" resultMap="StudyArticleResult">
        <include refid="selectArticleVo"/>
        where article_id = #{articleId}
    </select>

    <insert id="insertArticle" parameterType="StudyArticle" useGeneratedKeys="true" keyProperty="articleId">
        insert into study_article(
        <if test="title != null and title != ''">title,</if>
        <if test="content != null and content != ''">content,</if>
        <if test="coverImg != null">cover_img,</if>
        <if test="status != null and status != ''">status,</if>
        <if test="sort != null">sort,</if>
        <if test="remark != null and remark != ''">remark,</if>
        <if test="createBy != null and createBy != ''">create_by,</if>


        <if test="tags != null">tags,</if>
        <if test="summary != null">summary,</if>
        <if test="top != null">top,</if>
        <if test="voiceUrl != null">voice_url,</if>
        <if test="cozeId != null">coze_id,</if>
        <if test="versionId != null">version_id,</if>
        <if test="versionName != null">version_name,</if>
        <if test="subjectId != null">subject_id,</if>
        <if test="subjectName != null">subject_name,</if>
        <if test="gradeId != null">grade_id,</if>
        <if test="gradeName != null">grade_name,</if>
        <if test="volumeId != null">volume_id,</if>
        <if test="volumeName != null">volume_name,</if>
        create_time
        )values(
        <if test="title != null and title != ''">#{title},</if>
        <if test="content != null and content != ''">#{content},</if>
        <if test="coverImg != null">#{coverImg},</if>
        <if test="status != null and status != ''">#{status},</if>
        <if test="sort != null">#{sort},</if>
        <if test="remark != null and remark != ''">#{remark},</if>
        <if test="createBy != null and createBy != ''">#{createBy},</if>


        <if test="tags != null">#{tags},</if>
        <if test="summary != null">#{summary},</if>
        <if test="top != null">#{top},</if>
        <if test="voiceUrl != null">#{voiceUrl},</if>
        <if test="cozeId != null">#{cozeId},</if>
        <if test="versionId != null">#{versionId},</if>
        <if test="versionName != null">#{versionName},</if>
        <if test="subjectId != null">#{subjectId},</if>
        <if test="subjectName != null">#{subjectName},</if>
        <if test="gradeId != null">#{gradeId},</if>
        <if test="gradeName != null">#{gradeName},</if>
        <if test="volumeId != null">#{volumeId},</if>
        <if test="volumeName != null">#{volumeName},</if>
        sysdate()
        )
    </insert>

    <update id="updateArticle" parameterType="StudyArticle">
        update study_article
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="coverImg != null">cover_img = #{coverImg},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>


            <if test="tags != null">tags = #{tags},</if>
            <if test="summary != null">summary = #{summary},</if>
            <if test="viewCount != null">view_count = #{viewCount},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="collectCount != null">collect_count = #{collectCount},</if>
            <if test="top != null">top = #{top},</if>
            <if test="voiceUrl != null">voice_url = #{voiceUrl},</if>
            <if test="cozeId != null">coze_id = #{cozeId},</if>
            <if test="versionId != null">version_id = #{versionId},</if>
            <if test="versionName != null">version_name = #{versionName},</if>
            <if test="subjectId != null">subject_id = #{subjectId},</if>
            <if test="subjectName != null">subject_name = #{subjectName},</if>
            <if test="gradeId != null">grade_id = #{gradeId},</if>
            <if test="gradeName != null">grade_name = #{gradeName},</if>
            <if test="volumeId != null">volume_id = #{volumeId},</if>
            <if test="volumeName != null">volume_name = #{volumeName},</if>
            update_time = sysdate()
        </trim>
        where article_id = #{articleId}
    </update>

    <delete id="deleteArticleById" parameterType="Long">
        delete from study_article where article_id = #{articleId}
    </delete>

    <delete id="deleteArticleByIds" parameterType="String">
        delete from study_article where article_id in
        <foreach item="articleId" collection="array" open="(" separator="," close=")">
            #{articleId}
        </foreach>
    </delete>

    <update id="incrementViewCount">
        update study_article set view_count = view_count + 1 where article_id = #{articleId}
    </update>

    <update id="incrementLikeCount">
        update study_article set like_count = like_count + 1 where article_id = #{articleId}
    </update>

    <update id="decrementLikeCount">
        update study_article set like_count = like_count - 1 where article_id = #{articleId}
    </update>

    <update id="incrementCollectCount">
        update study_article set collect_count = collect_count + 1 where article_id = #{articleId}
    </update>

    <update id="decrementCollectCount">
        update study_article set collect_count = collect_count - 1 where article_id = #{articleId}
    </update>

    <!-- 统计文章数量 -->
    <select id="selectArticleCount" parameterType="String" resultType="Long">
        SELECT COUNT(1) 
        FROM study_article
        WHERE status = '0'
        <if test="type != null">
            <choose>
                <when test="type == 'month'">
                    AND DATE_FORMAT(create_time,'%Y%m') = DATE_FORMAT(CURDATE(),'%Y%m')
                </when>
            </choose>
        </if>
    </select>

    <!-- 获取文章增长趋势 -->
    <select id="selectArticleTrend" resultType="java.util.Map">
        SELECT 
            months.month,
            COALESCE(COUNT(a.article_id), 0) as count
        FROM (
            SELECT DATE_FORMAT(DATE_SUB(CURDATE(), INTERVAL 5 MONTH), '%Y-%m') as month
            UNION ALL
            SELECT DATE_FORMAT(DATE_SUB(CURDATE(), INTERVAL 4 MONTH), '%Y-%m') as month
            UNION ALL 
            SELECT DATE_FORMAT(DATE_SUB(CURDATE(), INTERVAL 3 MONTH), '%Y-%m') as month
            UNION ALL
            SELECT DATE_FORMAT(DATE_SUB(CURDATE(), INTERVAL 2 MONTH), '%Y-%m') as month
            UNION ALL
            SELECT DATE_FORMAT(DATE_SUB(CURDATE(), INTERVAL 1 MONTH), '%Y-%m') as month
            UNION ALL
            SELECT DATE_FORMAT(CURDATE(), '%Y-%m') as month
        ) months
        LEFT JOIN study_article a ON DATE_FORMAT(a.create_time, '%Y-%m') = months.month
            AND a.status = '0'
        GROUP BY months.month
        ORDER BY months.month ASC
    </select>

    <!-- 统计文章分类数据 -->
    <select id="selectCategoryStats" resultType="java.util.Map">
        SELECT 
            CASE 
                WHEN category_name IS NULL OR category_name = '' THEN '其他'
                ELSE category_name
            END as name,
            COUNT(1) as value
        FROM study_article
        WHERE status = '0'
        GROUP BY 
            CASE 
                WHEN category_name IS NULL OR category_name = '' THEN '其他'
                ELSE category_name
            END
        ORDER BY 
            CASE 
                WHEN name = '其他' THEN 1 
                ELSE 0 
            END,
            value DESC
    </select>

    <!-- 获取热门文章 -->
    <select id="selectTopArticles" resultType="java.util.Map">
        SELECT 
            article_id as id,
            title,
            view_count as viewCount
        FROM study_article
        WHERE status = '0'
        ORDER BY view_count DESC
        LIMIT #{limit}
    </select>

    <update id="updateArticleCozeId">
        update study_article 
        set coze_id = #{cozeId}
        where article_id = #{articleId}
    </update>

</mapper>